<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PokerApp"
             mc:Ignorable="d" d:DesignWidth="1180" d:DesignHeight="760"
             x:Class="PokerApp.MainWindow"
             x:DataType="vm:MainWindowViewModel"
             Background="#171a20">
    <UserControl.Styles>
        <Style Selector="Button.action-btn">
            <Setter Property="Background" Value="#3a445a" />
            <Setter Property="Foreground" Value="#f3f5fb" />
            <Setter Property="BorderBrush" Value="#55607a" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="14,10" />
        </Style>
        <Style Selector="Button.danger-btn">
            <Setter Property="Background" Value="#8b2a2a" />
            <Setter Property="Foreground" Value="#ffe8e8" />
            <Setter Property="BorderBrush" Value="#aa4444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.danger-btn:pointerover">
            <Setter Property="Background" Value="#a83838" />
        </Style>
    </UserControl.Styles>
    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*" Margin="12">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <TextBlock Grid.Column="0"
                       Text="{Binding SeriesProgressText}"
                       IsVisible="{Binding SeriesProgressVisible}"
                       VerticalAlignment="Center"
                       Foreground="#c8d8e8"
                       FontSize="17"
                       FontWeight="SemiBold" />
            <Button Grid.Column="1"
                    Classes="danger-btn"
                    Content="{Binding ExitMenuButtonText}"
                    HorizontalAlignment="Right"
                    Click="OnExitToMenuClick" />
        </Grid>
        <Grid Grid.Row="1" ColumnDefinitions="65*,35*" RowDefinitions="80*,20*">
        <Border Grid.Row="0" Grid.Column="0" Background="#232833" CornerRadius="10" Padding="10" Margin="0,0,10,10">
            <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Width="860" Height="600" RowDefinitions="Auto,Auto,Auto">
                    <ItemsControl Grid.Row="0" ItemsSource="{Binding BotSeats}" Margin="0,4,0,10">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PlayerRowVm">
                                <Grid Width="190" Margin="8,0">
                                    <Border Padding="10" CornerRadius="8"
                                            Background="#2e3440" BorderBrush="{Binding FrameBrush}" BorderThickness="2"
                                            Opacity="{Binding SeatOpacity}">
                                        <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#eceff4" HorizontalAlignment="Center" />
                                        <TextBlock Foreground="#a0a7b4" HorizontalAlignment="Center">
                                            <Run Text="Żetony: " />
                                            <Run Text="{Binding Chips}" />
                                        </TextBlock>
                                        <TextBlock Foreground="#88c0d0" HorizontalAlignment="Center" FontSize="12" Text="{Binding LastAction}" IsVisible="{Binding ShowLastAction}" />
                                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                            <Border Width="54" Height="78" CornerRadius="4" Background="#0f1115" BorderBrush="#3c4048" BorderThickness="1">
                                                <Grid>
                                                    <Image Source="{Binding Hole1}" Stretch="Uniform" IsVisible="{Binding !ShowHoleBacks}" />
                                                    <TextBlock Text="?" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#5f6368" FontSize="22" IsVisible="{Binding ShowHoleBacks}" />
                                                </Grid>
                                            </Border>
                                            <Border Width="54" Height="78" CornerRadius="4" Background="#0f1115" BorderBrush="#3c4048" BorderThickness="1">
                                                <Grid>
                                                    <Image Source="{Binding Hole2}" Stretch="Uniform" IsVisible="{Binding !ShowHoleBacks}" />
                                                    <TextBlock Text="?" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#5f6368" FontSize="22" IsVisible="{Binding ShowHoleBacks}" />
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Grid.Row="1" Background="#1f2430" CornerRadius="8" Padding="12" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                            <ItemsControl ItemsSource="{Binding Board}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CardSlotVm">
                                        <Border Width="72" Height="104" CornerRadius="6" Background="#0f1115" BorderBrush="#3c4048" BorderThickness="1">
                                            <Image Source="{Binding Image}" Stretch="Uniform" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Border Background="#2b3140" CornerRadius="6" Padding="12,8" MinWidth="110">
                                <StackPanel>
                                    <TextBlock Text="Pula" Foreground="#9aa0a6" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Pot}" Foreground="#e8eaed" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2" Margin="0,10,0,0" Width="320" IsVisible="{Binding HumanPanelVisible}">
                        <Border Padding="12" CornerRadius="8"
                                Background="#2d3546" BorderBrush="{Binding HumanSeat.FrameBrush}" BorderThickness="2"
                                Opacity="{Binding HumanSeat.SeatOpacity}">
                            <StackPanel Spacing="8">
                            <TextBlock Text="{Binding HumanSeat.Name}" FontWeight="SemiBold" Foreground="#f0f4ff" HorizontalAlignment="Center" />
                            <TextBlock Foreground="#b4bdcf" HorizontalAlignment="Center">
                                <Run Text="Żetony: " />
                                <Run Text="{Binding HumanSeat.Chips}" />
                            </TextBlock>
                            <TextBlock Foreground="#88c0d0" HorizontalAlignment="Center" FontSize="13" Text="{Binding HumanSeat.LastAction}" IsVisible="{Binding HumanSeat.ShowLastAction}" />
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <Border Width="78" Height="112" CornerRadius="4" Background="#0f1115" BorderBrush="#3c4048" BorderThickness="1">
                                    <Grid>
                                        <Image Source="{Binding HumanSeat.Hole1}" Stretch="Uniform" IsVisible="{Binding !HumanSeat.ShowHoleBacks}" />
                                        <TextBlock Text="?" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#5f6368" FontSize="24" IsVisible="{Binding HumanSeat.ShowHoleBacks}" />
                                    </Grid>
                                </Border>
                                <Border Width="78" Height="112" CornerRadius="4" Background="#0f1115" BorderBrush="#3c4048" BorderThickness="1">
                                    <Grid>
                                        <Image Source="{Binding HumanSeat.Hole2}" Stretch="Uniform" IsVisible="{Binding !HumanSeat.ShowHoleBacks}" />
                                        <TextBlock Text="?" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#5f6368" FontSize="24" IsVisible="{Binding HumanSeat.ShowHoleBacks}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Viewbox>
        </Border>

        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Background="#252a33" CornerRadius="10" Padding="10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="historia" Foreground="#9aa0a6" FontSize="14" Margin="0,0,0,8" />
                <ScrollViewer x:Name="HistoryScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding CurrentHandRounds}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:HandHistoryRoundVm">
                                <Border Background="#2b3140" CornerRadius="6" BorderBrush="#3c4458" BorderThickness="1" Margin="0,0,0,8" Padding="8">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding RoundName}" Foreground="#8fbcbb" FontWeight="Bold" FontSize="17" Margin="0,0,0,4" />
                                        <ItemsControl ItemsSource="{Binding Actions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:HandHistoryActionVm">
                                                    <StackPanel Spacing="4" Margin="0,1,0,1">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Foreground="#d8dee9" VerticalAlignment="Center" />
                                                            <TextBlock Text="prompt"
                                                                       Foreground="#cfd7e4"
                                                                       IsVisible="{Binding ShowPromptLink}"
                                                                       PointerPressed="OnHistoryPromptPressed">
                                                                <TextBlock.Styles>
                                                                    <Style Selector="TextBlock:pointerover">
                                                                        <Setter Property="TextDecorations" Value="Underline" />
                                                                    </Style>
                                                                </TextBlock.Styles>
                                                            </TextBlock>
                                                            <TextBlock Text="myśli"
                                                                       Foreground="#cfd7e4"
                                                                       IsVisible="{Binding ShowThoughtLink}"
                                                                       PointerPressed="OnHistoryThoughtPressed">
                                                                <TextBlock.Styles>
                                                                    <Style Selector="TextBlock:pointerover">
                                                                        <Setter Property="TextDecorations" Value="Underline" />
                                                                    </Style>
                                                                </TextBlock.Styles>
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <Border Background="#1d2430"
                                                                BorderBrush="#4b566d"
                                                                BorderThickness="1"
                                                                Padding="8"
                                                                IsVisible="{Binding ShowPromptPanel}">
                                                            <TextBox Text="{Binding PromptText}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90" MaxHeight="280" />
                                                        </Border>
                                                        <Border Background="#1d2430"
                                                                BorderBrush="#4b566d"
                                                                BorderThickness="1"
                                                                Padding="8"
                                                                IsVisible="{Binding ShowThoughtPanel}">
                                                            <TextBox Text="{Binding ThoughtText}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90" MaxHeight="280" />
                                                        </Border>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Background="#252a33" CornerRadius="10" Padding="14" Margin="0,0,10,0" IsVisible="{Binding ShowBottomDock}">
            <Viewbox Stretch="Uniform" HorizontalAlignment="Center">
                <Grid Width="760" Height="150">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,Auto,Auto,Auto,*" IsVisible="{Binding ShowHumanActionPanel}">
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="5" Text="Twój ruch" Foreground="#e8eaed" FontWeight="SemiBold" FontSize="20" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Foreground="#9aa0a6" Margin="0,8,8,8" Text="Do sprawdzenia:" FontSize="16" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Foreground="#e8eaed" Margin="0,8,18,8" Text="{Binding ToCall}" FontSize="18" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Foreground="#9aa0a6" Margin="0,8,8,8" Text="Min. podbicie:" FontSize="16" />
                        <TextBlock Grid.Row="1" Grid.Column="3" Foreground="#e8eaed" Margin="0,8,0,8" Text="{Binding MinRaise}" FontSize="18" />

                        <Button Grid.Row="2" Grid.Column="0" Grid.RowSpan="2" Classes="action-btn" Content="Pas" Click="OnFold" IsEnabled="{Binding HumanTurnActive}" MinHeight="48" MinWidth="110" FontSize="18" Margin="0,8,8,0" />
                        <Button Grid.Row="2" Grid.Column="1" Grid.RowSpan="2" Classes="action-btn" Content="{Binding CheckCallButtonText}" Click="OnCheckCall" IsEnabled="{Binding HumanTurnActive}" MinHeight="48" MinWidth="140" FontSize="18" Margin="0,8,8,0" />
                        <TextBox Grid.Row="2" Grid.Column="2" Grid.RowSpan="2" Width="120" Height="48" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" PlaceholderText="Podbicie" Text="{Binding RaiseText, Mode=TwoWay}" FontSize="18" Margin="0,8,8,0" />
                        <Button Grid.Row="2" Grid.Column="3" Grid.RowSpan="2" Classes="action-btn" Content="Podbij" Click="OnRaise" IsEnabled="{Binding CanRaiseNow}" MinHeight="48" MinWidth="120" FontSize="18" Margin="0,8,0,0" />
                    </Grid>
                    <Grid IsVisible="{Binding IsReplayMode}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                            <TextBlock Text="Powtórka" Foreground="#e8eaed" FontWeight="SemiBold" FontSize="20" HorizontalAlignment="Center" />
                            <Button Classes="action-btn"
                                    Content="NASTĘPNY RUCH"
                                    Click="OnNextReplayActionClick"
                                    IsEnabled="{Binding ReplayHasNextAction}"
                                    MinHeight="52"
                                    MinWidth="220"
                                    FontSize="20" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Viewbox>
        </Border>
        </Grid>
    </Grid>
</UserControl>
