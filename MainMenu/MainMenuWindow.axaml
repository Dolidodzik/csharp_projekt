<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PokerApp.MainMenuWindow"
        Title="PokerApp - Main Menu"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#111111">
    <Window.Styles>
        <Style Selector="TextBlock.menu-link">
            <Setter Property="FontSize" Value="60" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#eff7ff" />
            <Setter Property="Opacity" Value="0.9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="TextDecorations" Value="{x:Null}" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="TextBlock.menu-link:pointerover">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="TextDecorations" Value="Underline" />
        </Style>
        <Style Selector="TextBlock.hand-save-link">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="#d2e6ff" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="TextDecorations" Value="{x:Null}" />
        </Style>
        <Style Selector="TextBlock.hand-save-link:pointerover">
            <Setter Property="TextDecorations" Value="Underline" />
        </Style>
        <Style Selector="Button.replay-delete-btn">
            <Setter Property="Background" Value="#7d2f38" />
            <Setter Property="Foreground" Value="#ffeef0" />
            <Setter Property="BorderBrush" Value="#a24a55" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.replay-delete-btn:pointerover">
            <Setter Property="Background" Value="#94414b" />
        </Style>
    </Window.Styles>

    <Grid>
        <Border>
            <Image x:Name="MenuBackgroundImage" Stretch="UniformToFill" />
        </Border>

        <Border x:Name="OverlayShade" Background="#66000000" IsVisible="False" />

        <ContentControl x:Name="PersonalitiesHost" IsVisible="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

        <Grid x:Name="MenuLayer" IsVisible="True">
            <StackPanel Spacing="24"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="24">
                <TextBlock Text="Texas Hold'em Tournament"
                           HorizontalAlignment="Center"
                           FontSize="56"
                           FontWeight="Bold"
                           Foreground="#f8fbff" />
                <TextBlock Text="One table. One winner."
                           HorizontalAlignment="Center"
                           FontSize="24"
                           Foreground="#d6e2ef" />

                <TextBlock Text="Start Game"
                           Classes="menu-link"
                           HorizontalAlignment="Center"
                           PointerPressed="OnStartGamePressed" />
                <TextBlock Text="LLM agent personalities"
                           Classes="menu-link"
                           HorizontalAlignment="Center"
                           PointerPressed="OnPersonalitiesPressed" />
                <TextBlock Text="View replay"
                           Classes="menu-link"
                           HorizontalAlignment="Center"
                           PointerPressed="OnViewReplayPressed" />
                <TextBlock Text="Exit"
                           Classes="menu-link"
                           HorizontalAlignment="Center"
                           PointerPressed="OnExitPressed" />
            </StackPanel>
        </Grid>

        <ContentControl x:Name="GameHost" IsVisible="False" />

        <Border x:Name="SetupOverlay"
                IsVisible="False"
                Width="820"
                MaxWidth="960"
                Padding="20"
                CornerRadius="12"
                Background="#f0202733"
                BorderBrush="#88a6bf"
                BorderThickness="1.5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto" ColumnDefinitions="Auto,*" RowSpacing="10" ColumnSpacing="12">
                <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                           Text="Game setup"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="#f4f8ff" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Buy-in" VerticalAlignment="Center" Foreground="#d2deeb" />
                <TextBox x:Name="BuyInTextBox" Grid.Row="1" Grid.Column="1" PlaceholderText="e.g. 10000" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Small blind" VerticalAlignment="Center" Foreground="#d2deeb" />
                <TextBox x:Name="SmallBlindTextBox" Grid.Row="2" Grid.Column="1" PlaceholderText="e.g. 25" TextChanged="OnSmallBlindChanged" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Big blind" VerticalAlignment="Center" Foreground="#d2deeb" />
                <TextBlock x:Name="BigBlindInfoText" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Foreground="#8fbcbb" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Bot count" VerticalAlignment="Center" Foreground="#d2deeb" />
                <ComboBox x:Name="BotCountComboBox" Grid.Row="4" Grid.Column="1" SelectionChanged="OnBotCountChanged">
                    <ComboBoxItem Content="1" />
                    <ComboBoxItem Content="2" />
                    <ComboBoxItem Content="3" />
                </ComboBox>

                <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Spacing="8">
                    <Grid x:Name="Bot1Row" ColumnDefinitions="Auto,*,Auto,200,Auto,*" ColumnSpacing="12">
                        <TextBlock Grid.Column="0" Text="Bot 1 type" VerticalAlignment="Center" Foreground="#d2deeb" />
                        <ComboBox x:Name="Bot1TypeComboBox" Grid.Column="1" SelectionChanged="OnBotTypeChanged">
                            <ComboBoxItem Content="RandomBotPlayer" />
                            <ComboBoxItem Content="LlmBotPlayer" />
                        </ComboBox>
                        <TextBlock Grid.Column="2" Text="Personality" VerticalAlignment="Center" Foreground="#d2deeb" />
                        <ComboBox x:Name="Bot1PersonalityComboBox" Grid.Column="3" />
                        <TextBlock Grid.Column="4" Text="Name" VerticalAlignment="Center" Foreground="#d2deeb" />
                        <TextBox x:Name="Bot1NameTextBox" Grid.Column="5" PlaceholderText="Bot name" />
                    </Grid>
                    <Grid x:Name="Bot2Row" ColumnDefinitions="Auto,*,Auto,200,Auto,*" ColumnSpacing="12">
                        <TextBlock Grid.Column="0" Text="Bot 2 type" VerticalAlignment="Center" Foreground="#d2deeb" />
                        <ComboBox x:Name="Bot2TypeComboBox" Grid.Column="1" SelectionChanged="OnBotTypeChanged">
                            <ComboBoxItem Content="RandomBotPlayer" />
                            <ComboBoxItem Content="LlmBotPlayer" />
                        </ComboBox>
                        <TextBlock Grid.Column="2" Text="Personality" VerticalAlignment="Center" Foreground="#d2deeb" />
                        <ComboBox x:Name="Bot2PersonalityComboBox" Grid.Column="3" />
                        <TextBlock Grid.Column="4" Text="Name" VerticalAlignment="Center" Foreground="#d2deeb" />
                        <TextBox x:Name="Bot2NameTextBox" Grid.Column="5" PlaceholderText="Bot name" />
                    </Grid>
                    <Grid x:Name="Bot3Row" ColumnDefinitions="Auto,*,Auto,200,Auto,*" ColumnSpacing="12">
                        <TextBlock Grid.Column="0" Text="Bot 3 type" VerticalAlignment="Center" Foreground="#d2deeb" />
                        <ComboBox x:Name="Bot3TypeComboBox" Grid.Column="1" SelectionChanged="OnBotTypeChanged">
                            <ComboBoxItem Content="RandomBotPlayer" />
                            <ComboBoxItem Content="LlmBotPlayer" />
                        </ComboBox>
                        <TextBlock Grid.Column="2" Text="Personality" VerticalAlignment="Center" Foreground="#d2deeb" />
                        <ComboBox x:Name="Bot3PersonalityComboBox" Grid.Column="3" />
                        <TextBlock Grid.Column="4" Text="Name" VerticalAlignment="Center" Foreground="#d2deeb" />
                        <TextBox x:Name="Bot3NameTextBox" Grid.Column="5" PlaceholderText="Bot name" />
                    </Grid>
                </StackPanel>

                <Border x:Name="LlmConfigPanel"
                        Grid.Row="6"
                        Grid.ColumnSpan="2"
                        CornerRadius="8"
                        Padding="10"
                        Background="#44101010"
                        BorderBrush="#55708095"
                        BorderThickness="1"
                        Opacity="0.45"
                        IsEnabled="False">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*" RowSpacing="8" ColumnSpacing="10">
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="LLM Settings (used by all LLM bots)" Foreground="#d2deeb" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="API URL" VerticalAlignment="Center" Foreground="#d2deeb" />
                        <TextBox x:Name="ApiUrlTextBox" Grid.Row="1" Grid.Column="1" PlaceholderText="http://127.0.0.1:8111/v1" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Model" VerticalAlignment="Center" Foreground="#d2deeb" />
                        <TextBox x:Name="ModelTextBox" Grid.Row="2" Grid.Column="1" PlaceholderText="e.g. qwen/qwen3-32b" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="API Key" VerticalAlignment="Center" Foreground="#d2deeb" />
                        <TextBox x:Name="ApiKeyTextBox" Grid.Row="3" Grid.Column="1" PasswordChar="*" />
                    </Grid>
                </Border>

                <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                    <TextBlock x:Name="SetupErrorTextBlock" Foreground="#ff9191" VerticalAlignment="Center" />
                    <TextBlock Text="Cancel" Classes="menu-link" FontSize="30" PointerPressed="OnCancelSetupPressed" />
                    <TextBlock Text="Start" Classes="menu-link" FontSize="30" PointerPressed="OnConfirmSetupPressed" />
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="WinnerOverlay"
                IsVisible="False"
                Width="560"
                MaxWidth="860"
                Padding="24"
                CornerRadius="12"
                Background="#f0202733"
                BorderBrush="#88a6bf"
                BorderThickness="1.5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Spacing="14">
                <TextBlock Text="Tournament finished"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="#f4f8ff"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="WinnerText"
                           FontSize="26"
                           Foreground="#d8f0e2"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Back to main menu"
                           Classes="menu-link"
                           FontSize="32"
                           HorizontalAlignment="Center"
                           PointerPressed="OnBackToMenuPressed" />
            </StackPanel>
        </Border>

        <Border x:Name="HandResultOverlay"
                IsVisible="False"
                Width="560"
                MaxWidth="860"
                Padding="24"
                CornerRadius="12"
                Background="#f0202733"
                BorderBrush="#88a6bf"
                BorderThickness="1.5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Spacing="14">
                <TextBlock Text="Hand finished"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="#f4f8ff"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="HandWinnerText"
                           FontSize="26"
                           Foreground="#d8f0e2"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
                <Grid x:Name="HandSaveRow">
                    <StackPanel x:Name="HandSaveActivePanel" Orientation="Vertical" Spacing="8" HorizontalAlignment="Center" Width="380">
                        <TextBox x:Name="HandNameTextBox" PlaceholderText="Hand name (required for save)" />
                        <TextBlock x:Name="HandSaveErrorTextBlock" Foreground="#ff9191" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                            <CheckBox x:Name="SaveHandCheckBox" VerticalAlignment="Center" IsCheckedChanged="OnSaveHandCheckChanged" />
                            <TextBlock Text="Save this hand"
                                       Classes="hand-save-link"
                                       VerticalAlignment="Center"
                                       PointerPressed="OnSaveHandLabelPressed" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="HandSavedLabel"
                               Text="Saved"
                               FontSize="18"
                               Foreground="#7a8a9e"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsVisible="False" />
                </Grid>
                <TextBlock x:Name="HandResultActionText"
                           Text="Next"
                           Classes="menu-link"
                           FontSize="32"
                           HorizontalAlignment="Center"
                           PointerPressed="OnNextHandPressed" />
            </StackPanel>
        </Border>

        <Border x:Name="ExitConfirmOverlay"
                IsVisible="False"
                Width="480"
                MaxWidth="720"
                Padding="24"
                CornerRadius="12"
                Background="#f0202733"
                BorderBrush="#88a6bf"
                BorderThickness="1.5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Spacing="18">
                <TextBlock Text="Exit to main menu?"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#f4f8ff"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
                <TextBlock Text="The tournament will end. Are you sure?"
                           FontSize="18"
                           Foreground="#d2deeb"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
                <StackPanel Orientation="Horizontal" Spacing="20" HorizontalAlignment="Center">
                    <TextBlock Text="Cancel"
                               Classes="menu-link"
                               FontSize="28"
                               PointerPressed="OnExitConfirmCancelPressed" />
                    <TextBlock Text="Yes, exit"
                               Classes="menu-link"
                               FontSize="28"
                               PointerPressed="OnExitConfirmYesPressed" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border x:Name="ReplayListOverlay"
                IsVisible="False"
                Width="680"
                MaxWidth="920"
                Padding="22"
                CornerRadius="12"
                Background="#f0202733"
                BorderBrush="#88a6bf"
                BorderThickness="1.5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
                <TextBlock Text="Saved hand replays"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#f4f8ff" />
                <ListBox x:Name="ReplayHandsListBox"
                         Grid.Row="1"
                         Background="#1a2230"
                         Foreground="#e8f0fa"
                         BorderBrush="#3a4a5e"
                         BorderThickness="1">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="2">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap" />
                                <Button Grid.Column="1"
                                        Classes="replay-delete-btn"
                                        Content="Delete"
                                        Click="OnDeleteReplayClick" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                    <TextBlock x:Name="ReplayErrorTextBlock" Foreground="#ff9191" VerticalAlignment="Center" />
                    <TextBlock Text="Close" Classes="menu-link" FontSize="26" PointerPressed="OnCloseReplayListPressed" />
                    <TextBlock Text="Open replay" Classes="menu-link" FontSize="26" PointerPressed="OnOpenReplayPressed" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
