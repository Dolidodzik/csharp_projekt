{
  "metadata": [
    {
      "src": [
        {
          "files": ["PokerApp.csproj"],
          "src": ".."
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net8.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/**.md",
          "articles/**.md",
          "articles/**/toc.yml",
          "toc.yml",
          "index.md"
        ]
      }
    ],
    "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "dest": "_site",
    "globalMetadata": {
      "_appTitle": "PokerApp — dokumentacja kodu",
      "_appFooter": "PokerApp / projekt URZ"
    }
  }
}
